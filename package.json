{
	"name": "vamos",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "nuxt generate",
		"dev": "nuxt dev",
		"preview": "nuxt preview",
		"postinstall": "nuxt prepare",
		"test": "vitest",
		"test:watch": "vitest --watch",
		"test:nuxt": "vitest --project nuxt",
		"test:e2e": "vitest --project e2e",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "oxfmt",
		"typecheck": "nuxi typecheck",
		"data:generate": "node scripts/generate-data.ts",
		"deploy": "nuxt generate && wrangler pages deploy",
		"prepare": "husky"
	},
	"dependencies": {
		"@nuxt/hints": "^1.0.0-alpha.9",
		"@nuxt/test-utils": "^4.0.0",
		"@nuxt/ui": "^4.5.0",
		"@nuxtjs/i18n": "^10.2.3",
		"dexie": "^4.3.0",
		"nuxt": "^4.3.1",
		"ts-fsrs": "^5.2.3",
		"vue": "^3.5.28",
		"vue-router": "^4.6.4"
	},
	"devDependencies": {
		"@iconify-json/lucide": "^1.2.95",
		"@nuxt/eslint": "^1.15.2",
		"@playwright/test": "^1.58.2",
		"@types/node": "^25.3.2",
		"@vitest/browser-playwright": "^4.0.18",
		"@vue/test-utils": "^2.4.6",
		"eslint": "^9.39.3",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"oxfmt": "^0.35.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18",
		"wrangler": "^4.71.0"
	},
	"lint-staged": {
		"*.{js,ts,vue,json}": "oxfmt --write",
		"*.{js,ts,vue}": "eslint --fix"
	}
}
